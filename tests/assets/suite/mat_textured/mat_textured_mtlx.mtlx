<?xml version="1.0"?>
<materialx version="1.39">
  <standard_surface name="shape_0_mat_surface" type="surfaceshader">
    <input name="metalness" type="float" value="0" />
    <input name="specular_roughness" type="float" value="1" />
    <input name="base_color" type="color3" nodegraph="NG_shape_0_mat" output="out_base_color" />
  </standard_surface>
  <nodegraph name="NG_shape_0_mat">
    <image name="img_base_color" type="color3">
      <input name="file" type="filename" value="texture_uv.png" />
    </image>
    <output name="out_base_color" type="color3" nodename="img_base_color" />
  </nodegraph>
  <surfacematerial name="shape_0_mat" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="shape_0_mat_surface" />
  </surfacematerial>
</materialx>
