#usda 1.0
(
    customLayerData = {
        dictionary pbrt = {
            string colorSpace = "srgb"
            dictionary film = {
                dictionary paramTypes = {
                    string filename = "string"
                    string xresolution = "integer"
                    string yresolution = "integer"
                }
                dictionary params = {
                    string filename = "int_indirect_box.exr"
                    int xresolution = 128
                    int yresolution = 128
                }
            }
            dictionary integrator = {
                dictionary paramTypes = {
                    string maxdepth = "integer"
                }
                dictionary params = {
                    int maxdepth = 12
                }
                string type = "path"
            }
            dictionary sampler = {
                dictionary paramTypes = {
                    string pixelsamples = "integer"
                }
                dictionary params = {
                    int pixelsamples = 256
                }
                string type = "independent"
            }
        }
    }
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "World"
{
    def Mesh "shape_0" (
        prepend apiSchemas = ["MaterialBindingAPI"]
        customData = {
            dictionary pbrtAreaLight = {
                dictionary paramTypes = {
                    string L = "rgb"
                }
                dictionary params = {
                    double[] L = [40, 40, 40]
                }
                string type = "diffuse"
            }
        }
    )
    {
        int[] faceVertexCounts = [3, 3]
        int[] faceVertexIndices = [2, 1, 0, 3, 2, 0]
        rel material:binding = </World/shape_0_mat>
        point3f[] points = [(-0.7, 3.95, 0.7), (0.7, 3.95, 0.7), (0.7, 3.95, -0.7), (-0.7, 3.95, -0.7)]
        uniform token subdivisionScheme = "none"
    }

    over "shape_0_mat" (
        customData = {
            dictionary pbrt = {
                dictionary paramTypes = {
                    string reflectance = "rgb"
                }
                dictionary params = {
                    double[] reflectance = [0, 0, 0]
                }
                string type = "diffuse"
            }
        }
        prepend references = @int_indirect_box_mtlx.mtlx@
    )
    {
    }

