# Corpus: a UV-mapped quad with an imagemap diffuse under a constant infinite
# light. Isolates imagemap texture sampling over explicit mesh UVs — the
# gradient texture (R=u, G=v) makes any UV flip/mirror/swap visible.
LookAt 0 0 3.2  0 0 0  0 1 0
Camera "perspective" "float fov" 40
Sampler "independent" "integer pixelsamples" 256
Integrator "path" "integer maxdepth" 5
Film "rgb" "integer xresolution" 128 "integer yresolution" 128 "string filename" "texture_quad.exr"
WorldBegin

LightSource "infinite" "rgb L" [1 1 1]

Texture "uvtex" "spectrum" "imagemap" "string filename" "texture_uv.png"

AttributeBegin
  Material "diffuse" "texture reflectance" "uvtex"
  Shape "trianglemesh"
    "point3 P" [ -1 -1 0  1 -1 0  1 1 0  -1 1 0 ]
    "integer indices" [ 0 1 2  0 2 3 ]
    "point2 uv" [ 0 0  1 0  1 1  0 1 ]
AttributeEnd
