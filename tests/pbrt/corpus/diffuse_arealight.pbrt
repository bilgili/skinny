# Corpus: a diffuse sphere on a floor lit by a rectangular area light.
# Isolates Lambert reflectance + area-light transport.
LookAt 0 1 6  0 0 0  0 1 0
Camera "perspective" "float fov" 35
Sampler "independent" "integer pixelsamples" 256
Integrator "path" "integer maxdepth" 8
Film "rgb" "integer xresolution" 128 "integer yresolution" 128 "string filename" "diffuse_arealight.exr"
WorldBegin

AttributeBegin
  AreaLightSource "diffuse" "rgb L" [12 12 12]
  Translate 0 4 0
  Shape "trianglemesh" "point3 P" [ -1.5 0 -1.5  1.5 0 -1.5  1.5 0 1.5  -1.5 0 1.5 ] "integer indices" [ 0 1 2 0 2 3 ]
AttributeEnd

AttributeBegin
  Material "diffuse" "rgb reflectance" [0.7 0.5 0.4]
  Shape "sphere" "float radius" 1
AttributeEnd

AttributeBegin
  Material "diffuse" "rgb reflectance" [0.5 0.5 0.5]
  Translate 0 -1 0
  Shape "trianglemesh" "point3 P" [ -6 0 -6  6 0 -6  6 0 6  -6 0 6 ] "integer indices" [ 0 1 2 0 2 3 ]
AttributeEnd
